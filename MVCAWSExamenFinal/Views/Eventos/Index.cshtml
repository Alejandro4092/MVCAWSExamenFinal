@model List<Evento>
@{
    string bucketUrl =
        ViewData["BUCKETURL"]?.ToString() ?? "";
}
<h1>Eventos</h1>

<form method="post">

    <label>Categoría</label>

    <select name="idcategoria"
            class="form-select">

        <option value="">
            Todas las categorías
        </option>

        @foreach (SelectListItem item in
                (IEnumerable<SelectListItem>)ViewData["CATEGORIAS"])
        {
            <option value="@item.Value">
                @item.Text
            </option>
        }

    </select>

    <br />

    <button class="btn btn-primary">
        Buscar
    </button>

</form>

<hr />

@if (Model.Count == 0)
{
    <div class="alert alert-warning">
        No hay eventos para esta categoría.
    </div>
}
else
{
    <div class="row">

        @foreach (var evento in Model)
        {
            <div class="col-md-4 mb-3">

                <div class="card">

                    <img src="@bucketUrl@evento.Imagen" alt="@evento.Imagen"
                         class="card-img-top">

                    <div class="card-body">

                        <h5>
                            @evento.Nombre
                        </h5>

                        <p>
                            @evento.Artista
                        </p>

                    </div>

                </div>

            </div>
        }

    </div>
}